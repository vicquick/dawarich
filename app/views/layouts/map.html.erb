<!DOCTYPE html>
<html data-theme="<%= app_theme %>" data-self-hosted="<%= @self_hosted %>">
  <head>
    <title><%= full_title(yield(:title)) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <link rel="preconnect" href="https://unpkg.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <%= action_cable_meta_tag %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css"/>
    <%# vicquick fork: MapLibre control styling (zoom/compass/geolocate) — was missing %>
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.12.0/dist/maplibre-gl.css" />

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head_scripts %>
    <%= javascript_include_tag "https://unpkg.com/protomaps-leaflet@5.0.0/dist/protomaps-leaflet.js", defer: true %>

    <%= render 'application/favicon' %>
    <%= Sentry.get_trace_propagation_meta.html_safe if Sentry.initialized? %>
    <% if !DawarichSettings.self_hosted? %>
      <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
    <% end %>
  </head>

  <body class='h-screen !h-[100dvh] overflow-hidden relative'>
    <!-- Fixed Navbar -->
    <div class='fixed w-full z-40 h-[calc(4rem+env(safe-area-inset-top))] pt-[env(safe-area-inset-top)] border-b border-base-content/10'>
      <div class='container mx-auto h-full w-full flex items-center'>
        <%= render 'shared/navbar' %>
      </div>
    </div>

    <!-- Flash Messages - Fixed below navbar -->
    <div class='fixed top-[calc(4rem+env(safe-area-inset-top))] w-full z-50'>
      <div class='container mx-auto px-5'>
        <%= render 'shared/flash' %>
      </div>
    </div>

    <!-- Full Screen Map Container -->
    <div class='absolute top-[calc(4rem+env(safe-area-inset-top))] left-0 right-0 bottom-0 w-full z-20 flex flex-col'>
      <%= yield %>
    </div>

    <% if user_signed_in? && current_user.imports.exists?(demo: true) %>
      <div id="demo-data-banner" class="fixed bottom-0 left-1/2 -translate-x-1/2 z-30 mb-[calc(1rem+env(safe-area-inset-bottom))]" data-controller="demo-banner">
        <div class="alert alert-info shadow-lg py-1.5 px-3 flex items-center gap-1.5 rounded-lg whitespace-nowrap text-sm">
          <span class="font-medium" data-demo-banner-target="label">You're viewing demo data.</span>
          <span data-demo-banner-target="loadingState" class="hidden">
            <span class="loading loading-spinner loading-xs text-info"></span>
          </span>
          <%= button_to "Delete",
              demo_data_settings_onboarding_path,
              method: :delete,
              form: {
                data: {
                  turbo: false,
                  action: "submit->demo-banner#confirmDelete"
                }
              },
              data: { "demo-banner-target": "deleteButton" },
              class: "btn btn-error btn-xs" %>
          <button class="btn btn-ghost btn-xs btn-square" data-action="demo-banner#dismiss">
            <%= icon 'x', class: 'w-3 h-3' %>
          </button>
        </div>
      </div>
    <% end %>

    <!-- Fixed Footer (hidden by default) -->
    <div id='map-footer' class='fixed bottom-[env(safe-area-inset-bottom)] left-0 right-0 z-30 hidden'>
      <%= render 'shared/legal_footer' %>
    </div>

    <%= render 'map/onboarding_modal', auto_open: true %>
  </body>
</html>
