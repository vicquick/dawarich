<%# Directions UI (vicquick fork — Valhalla-backed routing on the map).
    No standalone toggle button any more: directions start from a place's
    detail sheet (Directions action). This panel only shows the active route. %>
<div id="directions-panel"
     class="hidden card bg-base-100 shadow-xl"
     style="position:absolute;left:1rem;bottom:1.5rem;z-index:500;width:min(20rem,calc(100vw - 2rem));max-height:55vh;overflow:auto;border-radius:16px">
  <div class="card-body p-3 gap-2">
    <div class="flex items-center justify-between gap-2">
      <span class="font-semibold text-sm">Directions</span>
      <div class="flex items-center gap-1">
        <select id="directions-mode" class="select select-xs select-bordered"
                onchange="window.dawarichDirections && window.dawarichDirections.setCosting(this.value)">
          <option value="auto">🚗 Drive</option>
          <option value="bicycle">🚲 Bike</option>
          <option value="pedestrian">🚶 Walk</option>
        </select>
        <button type="button" class="btn btn-xs btn-ghost btn-circle" title="Close"
                onclick="window.dawarichDirections && window.dawarichDirections.disable()">✕</button>
      </div>
    </div>
    <p id="directions-status" class="text-xs opacity-70">Pick a place, then tap Directions.</p>
    <p id="directions-summary" class="text-base font-bold text-primary"></p>
    <ol id="directions-turns" class="m-0 p-0 list-none"></ol>
  </div>
</div>
