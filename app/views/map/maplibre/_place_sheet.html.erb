<%# Place detail bottom sheet (vicquick fork) — Google-Maps-style %>
<%# Dimming backdrop — gives the sheet a clear "overlay" background; tap to close. %>
<div id="place-sheet-backdrop"
     style="position:fixed; inset:0; z-index:590; background:rgba(0,0,0,.32);
            opacity:0; pointer-events:none; transition:opacity .28s ease;"></div>
<div data-controller="place-sheet"
     data-place-sheet-api-key-value="<%= current_user.api_key %>"
     data-place-sheet-starred-tag-id-value="5"
     data-place-sheet-tags-value="<%= current_user.tags.order(:name).map { |t| { id: t.id, name: t.name, color: t.color, icon: t.icon } }.to_json %>"
     style="position:fixed; left:0; right:0; bottom:0; z-index:600; height:34vh;
            transform:translateY(100%); transition:transform .28s ease, height .28s ease;
            background:oklch(var(--b1)); color:oklch(var(--bc));
            border-top-left-radius:18px; border-top-right-radius:18px;
            box-shadow:0 -6px 24px rgba(0,0,0,.25); overflow:hidden; display:flex; flex-direction:column;"
     class="bg-base-100 text-base-content">

  <%# drag handle / pull-up %>
  <div data-action="click->place-sheet#togglePullUp"
       style="cursor:grab; padding:8px 0 4px; display:flex; justify-content:center; flex:0 0 auto;">
    <span style="width:42px; height:5px; border-radius:3px; background:rgba(128,128,128,.5); display:block;"></span>
  </div>

  <div style="padding:0 18px 14px; overflow:auto; flex:1 1 auto;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
      <div style="min-width:0;">
        <button type="button" data-place-sheet-target="tagBadge"
                data-action="click->place-sheet#toggleTagPicker"
                style="display:inline-flex; align-items:center; gap:4px; border:0; cursor:pointer;
                       font-size:.7rem; font-weight:600; color:#fff; background:#9ca3af;
                       padding:3px 10px; border-radius:999px; margin-bottom:5px;">+ Label</button>
        <h3 data-place-sheet-target="title" style="margin:0; font-size:1.15rem; font-weight:700; line-height:1.2;">Place</h3>
        <p data-place-sheet-target="address" style="margin:2px 0 0; font-size:.85rem; opacity:.75;"></p>
        <p data-place-sheet-target="meta" style="margin:2px 0 0; font-size:.72rem; opacity:.55;"></p>
      </div>
      <button type="button" data-action="click->place-sheet#close" aria-label="Close"
              class="btn btn-ghost btn-sm btn-circle">✕</button>
    </div>

    <%# Tag picker — choose what kind of place this is (re-tags it). %>
    <div data-place-sheet-target="tagPicker" hidden
         style="display:flex; gap:6px; flex-wrap:wrap; margin-top:10px;"></div>

    <%# INFO mode: actions + enrichment %>
    <div data-place-sheet-target="info">
      <div style="display:flex; gap:8px; margin-top:14px; flex-wrap:wrap;">
        <button type="button" data-action="click->place-sheet#directions" class="btn btn-primary btn-sm gap-1">
          <%= icon 'route' %> Directions
        </button>
        <button type="button" data-action="click->place-sheet#save" class="btn btn-outline btn-sm gap-1">
          ⭐ <span data-save-label>Save</span>
        </button>
        <button type="button" data-action="click->place-sheet#share" class="btn btn-outline btn-sm gap-1">
          🔗 <span data-share-label>Share</span>
        </button>
      </div>
      <div data-place-sheet-target="enrichment" style="margin-top:14px;"></div>
    </div>

    <%# DIRECTIONS mode: the route panel lives inside the sheet (no separate
        floating popup). directions_manager fills these by id. %>
    <div id="directions-panel" data-place-sheet-target="directions" class="hidden" style="margin-top:14px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
        <button type="button" data-action="click->place-sheet#backToInfo" class="btn btn-ghost btn-sm gap-1">‹ Place</button>
        <select id="directions-mode" class="select select-sm select-bordered"
                onchange="window.dawarichDirections && window.dawarichDirections.setCosting(this.value)">
          <option value="auto">🚗 Drive</option>
          <option value="bicycle">🚲 Bike</option>
          <option value="pedestrian">🚶 Walk</option>
        </select>
      </div>
      <p id="directions-status" style="margin:10px 0 0; font-size:.8rem; opacity:.7;">Locating you…</p>
      <p id="directions-summary" style="margin:6px 0 0; font-size:1.05rem; font-weight:700; color:#2563eb;"></p>
      <ol id="directions-turns" style="margin:10px 0 0; padding:0; list-style:none;"></ol>
    </div>
  </div>
</div>
