<%# Place detail bottom sheet (vicquick fork) — Google-Maps-style %>
<%# Dimming backdrop — gives the sheet a clear "overlay" background; tap to close. %>
<div id="place-sheet-backdrop"
     style="position:fixed; inset:0; z-index:590; background:rgba(0,0,0,.32);
            opacity:0; pointer-events:none; transition:opacity .28s ease;"></div>
<div data-controller="place-sheet"
     data-place-sheet-api-key-value="<%= current_user.api_key %>"
     data-place-sheet-starred-tag-id-value="5"
     data-place-sheet-tags-value="<%= current_user.tags.order(:name).map { |t| { id: t.id, name: t.name, color: t.color, icon: t.icon } }.to_json %>"
     style="position:fixed; left:0; right:0; bottom:0; z-index:600; height:34vh;
            transform:translateY(100%); transition:transform .28s ease, height .28s ease;
            background:oklch(var(--b1)); color:oklch(var(--bc));
            border-top-left-radius:18px; border-top-right-radius:18px;
            box-shadow:0 -6px 24px rgba(0,0,0,.25); overflow:hidden; display:flex; flex-direction:column;"
     class="bg-base-100 text-base-content">

  <%# drag handle — drag up/down to resize, tap to toggle %>
  <div data-place-sheet-target="handle"
       style="cursor:grab; padding:10px 0 6px; display:flex; justify-content:center; flex:0 0 auto; touch-action:none;">
    <span style="width:44px; height:5px; border-radius:3px; background:rgba(128,128,128,.55); display:block;"></span>
  </div>

  <div style="padding:0 18px 14px; overflow:auto; flex:1 1 auto;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
      <div style="min-width:0;">
        <h3 data-place-sheet-target="title" style="margin:0; font-size:1.15rem; font-weight:700; line-height:1.2;">Place</h3>
        <p data-place-sheet-target="address" style="margin:2px 0 0; font-size:.85rem; opacity:.75;"></p>
        <p data-place-sheet-target="meta" style="margin:2px 0 0; font-size:.72rem; opacity:.55;"></p>
      </div>
      <button type="button" data-action="click->place-sheet#close" aria-label="Close"
              class="btn btn-ghost btn-sm btn-circle">✕</button>
    </div>

    <%# INFO mode: actions + enrichment %>
    <div data-place-sheet-target="info">
      <div style="display:flex; gap:8px; margin-top:14px; flex-wrap:wrap;">
        <button type="button" data-action="click->place-sheet#directions" class="btn btn-primary btn-sm gap-1">
          <%= icon 'route' %> Directions
        </button>
        <%# One button: "Save" when untagged, or the current category (colour) when
            saved. Tapping it opens the category picker. %>
        <button type="button" data-place-sheet-target="categoryBtn"
                data-action="click->place-sheet#toggleTagPicker"
                class="btn btn-sm gap-1">⭐ Save</button>
        <button type="button" data-action="click->place-sheet#share" class="btn btn-outline btn-sm gap-1">
          🔗 <span data-share-label>Share</span>
        </button>
      </div>

      <%# Category picker (chips) — opens from the category button %>
      <div data-place-sheet-target="tagPicker" hidden
           style="display:flex; gap:6px; flex-wrap:wrap; margin-top:12px;"></div>

      <div data-place-sheet-target="enrichment" style="margin-top:14px;"></div>
    </div>

    <%# DIRECTIONS mode: the route panel lives inside the sheet (no separate
        floating popup). directions_manager fills these by id. %>
    <div id="directions-panel" data-place-sheet-target="directions" class="hidden" style="margin-top:12px;">
      <%# Trip planner — editable Start/End (Google-Maps style). Tap a field to change it. %>
      <div id="directions-trip" style="display:none;">
        <div class="trip-rows">
          <span class="trip-spine" aria-hidden="true"></span>
          <button type="button" data-action="click->place-sheet#editEndpoint" data-end="start" class="trip-field">
            <span class="trip-dot trip-dot--start"></span>
            <span data-place-sheet-target="startLabel" class="trip-text">Your location</span>
          </button>
          <button type="button" data-action="click->place-sheet#editEndpoint" data-end="end" class="trip-field">
            <span class="trip-dot trip-dot--end"></span>
            <span data-place-sheet-target="endLabel" class="trip-text">Destination</span>
          </button>
          <button type="button" data-action="click->place-sheet#swapEnds" class="trip-swap" aria-label="Swap start and destination">⇅</button>
        </div>
        <%# inline endpoint picker — searches saved places + Photon %>
        <div data-place-sheet-target="endpointPicker" hidden class="trip-picker">
          <input type="text" data-place-sheet-target="endpointInput"
                 data-action="input->place-sheet#endpointSearch keydown->place-sheet#endpointKeydown"
                 placeholder="Search a place" class="trip-input" autocomplete="off" aria-label="Search a place">
          <ul data-place-sheet-target="endpointResults" class="trip-results"></ul>
        </div>
      </div>

      <%# PREVIEW header: back to place + travel-mode chips (hidden during active nav). %>
      <div id="directions-preview-header" style="display:flex; align-items:center; gap:8px;">
        <button type="button" data-action="click->place-sheet#backToInfo" class="btn btn-ghost btn-sm gap-1" style="flex:0 0 auto;">‹</button>
        <%# Modes, Google order: Walk (default) → Bike → Transit → Drive. Scrolls
            sideways on narrow screens so all stay reachable. %>
        <div style="display:flex; gap:6px; overflow-x:auto; -webkit-overflow-scrolling:touch; flex:1 1 auto; padding-bottom:2px;" role="group" aria-label="Travel mode">
          <button type="button" data-action="click->place-sheet#setMode" data-mode="pedestrian" class="btn btn-sm dir-mode btn-active" style="flex:0 0 auto;">🚶 Walk</button>
          <button type="button" data-action="click->place-sheet#setMode" data-mode="bicycle" class="btn btn-sm dir-mode" style="flex:0 0 auto;">🚲 Bike</button>
          <button type="button" data-action="click->place-sheet#setMode" data-mode="transit" class="btn btn-sm dir-mode" style="flex:0 0 auto;">🚆 Transit</button>
          <button type="button" data-action="click->place-sheet#setMode" data-mode="auto" class="btn btn-sm dir-mode" style="flex:0 0 auto;">🚗 Drive</button>
        </div>
      </div>
      <%# Live nav banner — the next manoeuvre (big arrow + distance + street). %>
      <div id="directions-nav-banner"
           style="display:none; align-items:center; gap:12px; margin-top:12px; padding:10px 13px;
                  border-radius:14px; background:#1a73e8; color:#fff;">
        <span id="directions-nav-arrow" style="font-size:1.7rem; line-height:1; flex:0 0 auto;">↑</span>
        <div style="min-width:0;">
          <div id="directions-nav-dist" style="font-size:1.15rem; font-weight:800; line-height:1.1;"></div>
          <div id="directions-nav-instr" style="font-size:.85rem; opacity:.95; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></div>
        </div>
        <button type="button" id="directions-recenter" data-action="click->place-sheet#recenter" hidden
                style="margin-left:auto; flex:0 0 auto; background:rgba(255,255,255,.22); border:0; color:#fff;
                       border-radius:999px; padding:6px 12px; font-size:.8rem; font-weight:700; cursor:pointer;">◎ Re-center</button>
      </div>
      <p id="directions-status" style="margin:10px 0 0; font-size:.8rem; opacity:.7;">Locating you…</p>
      <p id="directions-summary" style="margin:6px 0 0; font-size:1.05rem; font-weight:700; color:#2563eb;"></p>

      <%# Route alternatives — tap to pick (only shown when >1 route). %>
      <div id="directions-routes" style="display:none; gap:8px; flex-wrap:wrap; margin-top:12px;"></div>

      <%# PREVIEW actions: Start nav + ride-hailing hand-off (opens Uber/Bolt). %>
      <div id="directions-preview-actions" style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-top:12px;">
        <button type="button" data-action="click->place-sheet#startNav" class="btn btn-primary btn-sm gap-1" style="font-weight:700;">▶ Start</button>
        <a id="ride-uber" href="#" target="_blank" rel="noopener" class="btn btn-outline btn-sm gap-1">🚕 Uber</a>
        <a id="ride-bolt" href="#" target="_blank" rel="noopener" class="btn btn-outline btn-sm gap-1">⚡ Bolt</a>
      </div>

      <%# NAV controls: 2D/3D toggle + End nav (back to preview). Shown only while navigating. %>
      <div id="directions-nav-controls" style="display:none; align-items:center; gap:8px; margin-top:12px;">
        <button type="button" id="directions-2d-toggle" data-action="click->place-sheet#toggle2D" class="btn btn-outline btn-sm gap-1">⊞ 2D</button>
        <button type="button" data-action="click->place-sheet#endNav" class="btn btn-error btn-sm gap-1" style="margin-left:auto;">✕ End</button>
      </div>

      <ol id="directions-turns" style="margin:10px 0 0; padding:0; list-style:none;"></ol>
    </div>
  </div>
</div>

<style>
  /* --- Trip planner (editable start/end) --- */
  #directions-trip { display:none; margin-bottom:12px; }
  .trip-rows { position:relative; display:flex; flex-direction:column; gap:8px; }
  .trip-spine { position:absolute; left:9px; top:18px; bottom:30px; width:2px;
    background:repeating-linear-gradient(rgba(128,128,128,.45) 0 3px, transparent 3px 6px); }
  .trip-field { display:flex; align-items:center; gap:11px; width:100%; text-align:left;
    border:0; background:color-mix(in oklch, oklch(var(--bc)) 7%, transparent); color:inherit;
    border-radius:12px; padding:11px 12px; font:inherit; font-size:.95rem; cursor:pointer; }
  .trip-field:hover { background:color-mix(in oklch, oklch(var(--bc)) 12%, transparent); }
  .trip-dot { flex:0 0 auto; width:11px; height:11px; border-radius:50%; z-index:1;
    box-shadow:0 0 0 3px oklch(var(--b1)); }
  .trip-dot--start { background:#1a73e8; }
  .trip-dot--end { background:#ea4335; border-radius:3px; }
  .trip-text { flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .trip-swap { position:absolute; right:6px; top:50%; transform:translateY(-50%);
    width:34px; height:34px; border:0; border-radius:50%; cursor:pointer; font-size:1rem;
    background:oklch(var(--b1)); color:inherit; box-shadow:0 1px 5px rgba(0,0,0,.18); }
  .trip-picker { margin-top:8px; }
  .trip-input { width:100%; border:1px solid color-mix(in oklch, oklch(var(--bc)) 18%, transparent);
    background:oklch(var(--b1)); color:inherit; border-radius:11px; padding:10px 12px; font:inherit; outline:none; }
  .trip-input:focus { border-color:color-mix(in oklch, oklch(var(--bc)) 34%, transparent);
    box-shadow:none !important; --tw-ring-shadow:0 0 #0000 !important; }
  .trip-results { list-style:none; margin:6px 0 0; padding:0; max-height:34vh; overflow:auto; }
  .trip-results li button { display:flex; align-items:center; gap:10px; width:100%; text-align:left;
    border:0; background:transparent; color:inherit; border-radius:9px; padding:9px 8px; cursor:pointer; font:inherit; }
  .trip-results li button:hover { background:color-mix(in oklch, oklch(var(--bc)) 10%, transparent); }
  .trip-res-dot { flex:0 0 auto; width:26px; height:26px; border-radius:50%;
    display:flex; align-items:center; justify-content:center; font-size:.9rem;
    background:color-mix(in oklch, oklch(var(--bc)) 12%, transparent); }
  .trip-res-sub { font-size:.76rem; opacity:.6; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  /* --- Routing mode: hide history-browsing chrome, slim the top --- */
  body.routing-active .map-date-float,
  body.routing-active [data-controller~="map-controls"],
  body.routing-active #map-button-cluster,
  body.routing-active .map-button-cluster { display:none !important; }
</style>
