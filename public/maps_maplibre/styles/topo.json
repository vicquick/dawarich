{
  "version": 8,
  "name": "Topographic (OpenTopoMap)",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://protomaps.github.io/basemaps-assets/sprites/v4/light",
  "sources": {
    "opentopo": {
      "type": "raster",
      "tiles": [
        "https://a.tile.opentopomap.org/{z}/{x}/{y}.png",
        "https://b.tile.opentopomap.org/{z}/{x}/{y}.png",
        "https://c.tile.opentopomap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "maxzoom": 17,
      "attribution": "© <a href=\"https://opentopomap.org\">OpenTopoMap</a> (CC-BY-SA), © <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors"
    }
  },
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#f0efe9" } },
    { "id": "opentopo", "type": "raster", "source": "opentopo" }
  ]
}
